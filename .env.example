# ═══════════════════════════════════════════════════════
# SUPERNATURAL Education Platform — Environment Variables
# Copy this file to .env and fill in your credentials
# ═══════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────
APP_NAME=SUPERNATURAL
APP_ENV=development
SECRET_KEY=your-very-secret-jwt-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ─────────────────────────────────────────────
# SQLite (Development - no setup needed)
DATABASE_URL=sqlite:///./supernatural.db

# PostgreSQL (Production)
# DATABASE_URL=postgresql://supernatural:supernatural@localhost:5432/supernatural

# ── Google OAuth / Calendar / Meet ───────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create project > Enable Calendar API
# 3. Create OAuth 2.0 credentials > Download JSON
# 4. Save as credentials/google_credentials.json
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
GOOGLE_CALENDAR_CREDENTIALS_FILE=credentials/google_credentials.json
GOOGLE_TOKEN_FILE=credentials/token.json

# ── Gmail / SMTP ─────────────────────────────────────────
# Use App Password (not your Gmail password)
# Go to Google Account > Security > App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=SUPERNATURAL Platform

# ── OpenAI (GPT-4o for Quiz & Feedback) ─────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# ── N8N ──────────────────────────────────────────────────
# Secret key that N8N uses to authenticate webhook calls
# Set same in N8N credentials as HTTP Header Auth
N8N_WEBHOOK_BASE_URL=https://n8n-q7j7.onrender.com/webhook
N8N_API_KEY=your-n8n-webhook-secret-key

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
